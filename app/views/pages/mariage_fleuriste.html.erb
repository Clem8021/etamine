<%= render "shared/navbar" %>

<div class="mariage-page">

  <section class="wedding-hero">
    <div class="hero-title-wrapper">
      <%= image_tag "rose.jpg", alt: "Rose", class: "hero-badge" %>
      <h1>Fleuriste Mariage</h1>
      <%= image_tag "rose.jpg", alt: "Rose", class: "hero-badge" %>
    </div>
    <p>
      L’Étamine s’occupe de fleurir votre mariage et s’adapte à vos besoins et votre budget.
      Prenez rendez-vous pour construire ensemble votre projet pour le Jour J !
    </p>
  </section>

  <section class="wedding-block">
    <h2>Forfait fleurs</h2>
    <ul class="brown-bullets">
      <li>Préparation du bouquet de mariée</li>
      <li>Décoration de la cérémonie (bancs, autel, arche…)</li>
      <li>Décorations de tables (centres de table, soliflores…)</li>
      <li>Boutonnières & accessoires fleuris</li>
    </ul>
  </section>

  <section class="wedding-gallery">
    <h2>Nos réalisations</h2>
    <div class="grid-2x2">
      <%= smart_image_tag "mariage_1.jpg", alt: "Réalisation mariage 1" %>
      <%= smart_image_tag "mariage_2.jpg", alt: "Réalisation mariage 2" %>
      <%= smart_image_tag "mariage_3.jpg", alt: "Réalisation mariage 3" %>
      <%= smart_image_tag "mariage_4.jpg", alt: "Réalisation mariage 4" %>
    </div>
  </section>

  <section class="wedding-cta">
    <div class="cta-wrapper">
      <%= link_to "Prendre contact", contact_path, class: "btn btn-primary" %>
      <%= image_tag "enveloppe.jpg", alt: "Enveloppe", class: "cta-badge" %>
    </div>
  </section>

</div>
