<%= render "shared/navbar" %>

<div class="mariage-page">

  <section class="wedding-hero">
    <h1>Wedding Design</h1>
    <p>
      L’Étamine n’est pas uniquement fleuriste : nous proposons aussi un service de Wedding Design.
    </p>
  </section>

  <section class="wedding-block">
    <h2>Que propose un Wedding Designer&nbsp;?</h2>
    <p>
      Le Wedding Designer conçoit avec vous l’esthétique de votre mariage : définir un thème,
      imaginer le décor et le fleurir en conséquence.
    </p>

    <h3>En bref</h3>
    <ul class="brown-bullets">
      <li><strong>Fleurissement du mariage</strong> — Bouquet de mariée, boutonnières, église, salle, arche…</li>
      <li><strong>Préparation de la salle</strong> — Dressage des tables, installation d’arche, coin photos…</li>
      <li><strong>Papeterie</strong> — Faire-part, Save the Date, marque-places, menus, lettrage panneaux…</li>
      <li><strong>Mise en scène</strong> — Photobooth, scénettes, bar à bonbons…</li>
      <li><strong>Décorations & locations</strong> — Recherche d’objets, vaisselle, éléments déco…</li>
      <li><strong>Logistique sur site</strong> — Livraisons, installation/désinstallation…</li>
    </ul>
  </section>

  <section class="wedding-video" data-controller="video-lightbox">
    <h2>Exemple de carterie</h2>
    <p class="muted">Faire-part, menus, marque-places…</p>

    <div class="video-card" role="button" tabindex="0"
        data-action="click->video-lightbox#open keydown.enter->video-lightbox#open keydown.space->video-lightbox#open">
      <div class="video-overlay">
        <span class="video-overlay-badge">▶︎ Voir en grand</span>
      </div>

      <video
        class="video-preview"
        muted
        playsinline
        preload="metadata"
        data-video-lightbox-target="preview">
        <source src="/videos/carterie.mp4" type="video/mp4">
      </video>
    </div>

    <!-- Lightbox -->
    <div class="video-lightbox hidden"
        data-video-lightbox-target="overlay"
        data-action="click->video-lightbox#closeOnBackdrop">
      <button type="button" class="video-lightbox-close"
              data-action="click->video-lightbox#close"
              aria-label="Fermer">✕</button>

      <div class="video-lightbox-inner" data-action="click->video-lightbox#stop">
        <video class="video-full" controls playsinline data-video-lightbox-target="player"
              poster="<%= asset_path('carterie_poster.jpg') %>">
          <source src="/videos/carterie.mp4" type="video/mp4">
        </video>
      </div>
    </div>
  </section>

  <section class="wedding-book immersive" data-controller="flipbook-lightbox">
    <h2 class="section-title">Le book — <em>L'histoire commence ici</em></h2>

    <div class="flipbook-card" role="button" tabindex="0"
        data-action="click->flipbook-lightbox#open keydown.enter->flipbook-lightbox#open keydown.space->flipbook-lightbox#open">
      <div class="flipbook-overlay-badge">📖 Feuilleter</div>

      <!-- Target du lightbox -->
      <div data-flipbook-lightbox-target="flipbookRoot">
        <!-- Controller flipbook (viewer PDF) -->
        <div class="flipbook-container"
              data-controller="flipbook"
              data-flipbook-url-value="/book_wedding.pdf">

            <div class="flipbook-toolbar">
              <button type="button" class="flipbook-btn"
                      data-flipbook-target="prev"
                      data-action="click->flipbook#prev">←</button>

              <span class="flipbook-page" data-flipbook-target="page">—</span>

              <button type="button" class="flipbook-btn"
                      data-flipbook-target="next"
                      data-action="click->flipbook#next">→</button>
            </div>

            <div data-flipbook-target="loader" class="flipbook-loader">Chargement du book…</div>
            <div data-flipbook-target="error"  class="flipbook-error hidden"></div>

            <div class="flipbook-viewer">
              <canvas data-flipbook-target="canvas"></canvas>
            </div>
          </div>
      </div>
    </div>

    <!-- Lightbox -->
    <div class="flipbook-lightbox hidden"
        data-flipbook-lightbox-target="overlay"
        data-action="click->flipbook-lightbox#closeOnBackdrop">
      <button type="button" class="flipbook-lightbox-close"
              data-action="click->flipbook-lightbox#close">✕</button>

      <div class="flipbook-lightbox-inner"
          data-flipbook-lightbox-target="inner"
          data-action="click->flipbook-lightbox#stop"></div>
    </div>

    <div class="flipbook-actions">
      <a href="/book_wedding.pdf" class="btn-download" download>Télécharger le book (PDF)</a>
    </div>
  </section>

  <section class="wedding-gallery">
    <h2>Nos réalisations</h2>
    <div class="grid-2x2">
      <%= smart_image_tag "mariage_1.jpg", alt: "Wedding design 1" %>
      <%= smart_image_tag "mariage_2.jpg", alt: "Wedding design 2" %>
      <%= smart_image_tag "mariage_3.jpg", alt: "Wedding design 3" %>
      <%= smart_image_tag "mariage_4.jpg", alt: "Wedding design 4" %>
    </div>
  </section>

  <section class="wedding-cta">
    <%= link_to "Prendre contact", contact_path, class: "btn btn-primary" %>
  </section>

</div>
