<%= render "shared/navbar" %>

<div class="mariage-page">

  <section class="wedding-hero">
    <div class="hero-title-wrapper">
      <%= image_tag "rose.jpg", alt: "Rose", class: "hero-badge" %>
      <h1>Wedding Design</h1>
      <%= image_tag "rose.jpg", alt: "Rose", class: "hero-badge" %>
    </div>

    <p>
      L’Étamine n’est pas uniquement fleuriste : nous proposons aussi un service de Wedding Design.
    </p>
  </section>

  <section class="wedding-block">
    <h2>Que propose un Wedding Designer&nbsp;?</h2>
    <p>
      Le Wedding Designer conçoit avec vous l’esthétique de votre mariage : définir un thème,
      imaginer le décor et le fleurir en conséquence.
    </p>

    <h3>En bref</h3>
    <ul class="brown-bullets">
      <li><strong>Fleurissement du mariage</strong> — Bouquet de mariée, boutonnières, église, salle, arche…</li>
      <li><strong>Préparation de la salle</strong> — Dressage des tables, installation d’arche, coin photos…</li>
      <li><strong>Papeterie</strong> — Faire-part, Save the Date, marque-places, menus, lettrage panneaux…</li>
      <li><strong>Mise en scène</strong> — Photobooth, scénettes, bar à bonbons…</li>
      <li><strong>Décorations & locations</strong> — Recherche d’objets, vaisselle, éléments déco…</li>
      <li><strong>Logistique sur site</strong> — Livraisons, installation/désinstallation…</li>
    </ul>
  </section>

  <section class="wedding-video" data-controller="video-lightbox">
    <h2>Exemple de carterie</h2>
    <p class="muted">Faire-part, menus, marque-places…</p>

    <div class="video-card" role="button" tabindex="0">

     <%= cl_video_tag("carterie",
          controls: true,
          autoplay: false,
          muted: true,
          class: "video-preview",
          preload: "metadata",
          poster: asset_path("carterie_poster.jpg"),
          data: { video_lightbox_target: "preview" }) %>
    </div>

    <!-- Lightbox -->
    <div class="video-lightbox hidden"
        data-video-lightbox-target="overlay"
        data-action="click->video-lightbox#closeOnBackdrop">
      <button type="button" class="video-lightbox-close"
              data-action="click->video-lightbox#close"
              aria-label="Fermer">✕</button>

      <div class="video-lightbox-inner" data-action="click->video-lightbox#stop">
        <video class="video-full" controls playsinline data-video-lightbox-target="player"
               poster="<%= cl_image_path('carterie_poster') %>">
          <source src="<%= cl_video_path("carterie") %>" type="video/mp4">
        </video>
      </div>
    </div>
  </section>


      <!-- BOOK -->
  <!-- BOOK -->
<section class="wedding-book immersive"
        data-controller="flipbook"
        data-flipbook-width-value="800"
        data-flipbook-height-value="1130"
        data-flipbook-images-value='[
          "/pages/page-00.jpg",
          "/pages/page-01.jpg",
          "/pages/page-02.jpg",
          "/pages/page-03.jpg",
          "/pages/page-04.jpg",
          "/pages/page-05.jpg",
          "/pages/page-06.jpg",
          "/pages/page-07.jpg",
          "/pages/page-08.jpg",
          "/pages/page-09.jpg",
          "/pages/page-10.jpg",
          "/pages/page-11.jpg",
          "/pages/page-12.jpg",
          "/pages/page-13.jpg",
          "/pages/page-14.jpg",
          "/pages/page-15.jpg"
        ]'>

  <h2 class="section-title">Le book — <em>L'histoire commence ici</em></h2>

  <div class="flipbook-actions">
    <button class="btn-open-book"
            data-action="click->flipbook#open">
      Feuilleter le book
    </button>

    <a href="/book_wedding.pdf" class="btn-download" download>
      Télécharger le book (PDF)
    </a>
  </div>

  <div class="flipbook-modal"
       data-flipbook-target="modal"
       data-action="click->flipbook#outside">

      <button class="close-book"
              data-action="click->flipbook#close">
        ✕
      </button>

      <div class="flipbook-stage">
        <div class="flipbook-container"></div>
      </div>

      <button class="nav prev"
              data-action="click->flipbook#prev">‹</button>

      <button class="nav next"
              data-action="click->flipbook#next">›</button>

  </div>

</section>

  <section class="wedding-gallery" data-controller="gallery">
    <h2>Nos réalisations</h2>

    <div class="grid-2x2">
      <%= smart_image_tag "mariage_1.png",
            data: { action: "click->gallery#open", gallery_target: "image" } %>

      <%= smart_image_tag "mariage_2.png",
            data: { action: "click->gallery#open", gallery_target: "image" } %>

      <%= smart_image_tag "mariage_3.png",
            data: { action: "click->gallery#open", gallery_target: "image" } %>

      <%= smart_image_tag "mariage_4.png",
            data: { action: "click->gallery#open", gallery_target: "image" } %>
    </div>

    <!-- MODAL -->
    <div class="gallery-modal" data-gallery-target="modal" data-action="click->gallery#outside">
      <button class="close-gallery" data-action="click->gallery#close">✕</button>
      <img data-gallery-target="fullImage" class="gallery-full-image" />
    </div>
  </section>

 <div class="wedding-cta">
    <div class="cta-wrapper">
      <%= link_to "→", contact_path, class: "btn-primary" %>
      <%= link_to image_tag("enveloppe.jpg", alt: "Envoyer un message", class: "cta-envelope"), contact_path %>
    </div>
  </div>

</div>
